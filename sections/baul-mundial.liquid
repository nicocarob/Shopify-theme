{% comment %}
  Copa del Mundo 2026 — Selección por continente con buscador
{% endcomment %}

{% liquid
  assign hero_title = section.settings.hero_title | default: 'FIFA WORLD CUP 2026'
  assign hero_subtitle = section.settings.hero_subtitle | default: 'USA · CANADÁ · MÉXICO — 48 SELECCIONES'
  assign mundial_logo = section.settings.mundial_logo
%}

{% render 'baul-header', section: section %}

<section class="bm-hero">
  <div class="bm-hero-radial"></div>
  <div class="bm-particles" aria-hidden="true">
    {% for i in (1..10) %}
      <span class="bm-particle bm-particle--{{ i }}"></span>
    {% endfor %}
  </div>
  <div class="bm-hero-inner rev">
    {% if mundial_logo != blank %}
      <img
        class="bm-logo"
        src="{{ mundial_logo | image_url: width: 400 }}"
        alt="{{ mundial_logo.alt | default: 'Logo Copa del Mundo' | escape }}"
        width="200"
        height="200"
        loading="eager"
      >
    {% endif %}
    <span class="bm-badge">Copa del Mundo 2026</span>
    <h1 class="bm-title">
      {% if hero_title contains '2026' %}
        {% assign title_parts = hero_title | split: '2026' %}
        {{- title_parts[0] -}}<em>2026</em>{{- title_parts[1] -}}
      {% else %}
        {{ hero_title }}
      {% endif %}
    </h1>
    <p class="bm-subtitle">{{ hero_subtitle }}</p>
    <div class="bm-divider"></div>
    <p class="bm-hint">Busca tu selección o elige por continente</p>
  </div>
</section>

<section class="bm-world" id="bm-mundial">
  <div class="sec-bg-grid"></div>
  <div class="bm-world-inner">
    <div class="bm-selected-banner" id="bm-selected-banner" hidden>
      <span class="bm-selected-flag" id="bm-selected-flag"></span>
      <span class="bm-selected-text">Buscando camisetas de <strong id="bm-selected-name"></strong>…</span>
    </div>

    <div class="bm-search-wrap">
      <label class="bm-search-label" for="bm-search">Buscar selección</label>
      <div class="bm-search-field">
        <span class="bm-search-icon" aria-hidden="true">🔍</span>
        <input
          type="search"
          id="bm-search"
          class="bm-search-input"
          placeholder="Ej: Argentina, España, Japón…"
          autocomplete="off"
          aria-label="Buscar selección por país"
        >
      </div>
      <p class="bm-search-hint" id="bm-search-hint" hidden>Sin resultados. Presiona Enter para buscar igual.</p>
    </div>

    <div class="bm-continents" id="bm-continents">
      <article class="bm-continent rev">
        <h2 class="bm-continent-title">América</h2>
        <ul class="bm-flag-grid">
          {% render 'baul-mundial-flag', name: 'Argentina', tag: 'argentina', flag: '🇦🇷' %}
          {% render 'baul-mundial-flag', name: 'Brasil', tag: 'brasil', flag: '🇧🇷' %}
          {% render 'baul-mundial-flag', name: 'Colombia', tag: 'colombia', flag: '🇨🇴' %}
          {% render 'baul-mundial-flag', name: 'Canadá', tag: 'canada', flag: '🇨🇦' %}
          {% render 'baul-mundial-flag', name: 'Ecuador', tag: 'ecuador', flag: '🇪🇨' %}
          {% render 'baul-mundial-flag', name: 'USA', tag: 'usa', flag: '🇺🇸' %}
          {% render 'baul-mundial-flag', name: 'México', tag: 'mexico', flag: '🇲🇽' %}
          {% render 'baul-mundial-flag', name: 'Paraguay', tag: 'paraguay', flag: '🇵🇾' %}
          {% render 'baul-mundial-flag', name: 'Uruguay', tag: 'uruguay', flag: '🇺🇾' %}
          {% render 'baul-mundial-flag', name: 'Panamá', tag: 'panama', flag: '🇵🇦' %}
          {% render 'baul-mundial-flag', name: 'Haití', tag: 'haiti', flag: '🇭🇹' %}
        </ul>
      </article>

      <article class="bm-continent rev">
        <h2 class="bm-continent-title">Europa</h2>
        <ul class="bm-flag-grid">
          {% render 'baul-mundial-flag', name: 'España', tag: 'espana', flag: '🇪🇸' %}
          {% render 'baul-mundial-flag', name: 'Francia', tag: 'francia', flag: '🇫🇷' %}
          {% render 'baul-mundial-flag', name: 'Alemania', tag: 'alemania', flag: '🇩🇪' %}
          {% render 'baul-mundial-flag', name: 'Portugal', tag: 'portugal', flag: '🇵🇹' %}
          {% render 'baul-mundial-flag', name: 'Inglaterra', tag: 'inglaterra', flag: '🏴󠁧󠁢󠁥󠁮󠁧󠁿' %}
          {% render 'baul-mundial-flag', name: 'Países Bajos', tag: 'paises-bajos', flag: '🇳🇱' %}
          {% render 'baul-mundial-flag', name: 'Bélgica', tag: 'belgica', flag: '🇧🇪' %}
          {% render 'baul-mundial-flag', name: 'Croacia', tag: 'croacia', flag: '🇭🇷' %}
          {% render 'baul-mundial-flag', name: 'Suiza', tag: 'suiza', flag: '🇨🇭' %}
          {% render 'baul-mundial-flag', name: 'Austria', tag: 'austria', flag: '🇦🇹' %}
          {% render 'baul-mundial-flag', name: 'Suecia', tag: 'suecia', flag: '🇸🇪' %}
          {% render 'baul-mundial-flag', name: 'Noruega', tag: 'noruega', flag: '🇳🇴' %}
          {% render 'baul-mundial-flag', name: 'Escocia', tag: 'escocia', flag: '🏴󠁧󠁢󠁳󠁣󠁴󠁿' %}
          {% render 'baul-mundial-flag', name: 'Chequia', tag: 'chequia', flag: '🇨🇿' %}
          {% render 'baul-mundial-flag', name: 'Bosnia', tag: 'bosnia', flag: '🇧🇦' %}
        </ul>
      </article>

      <article class="bm-continent rev">
        <h2 class="bm-continent-title">África</h2>
        <ul class="bm-flag-grid">
          {% render 'baul-mundial-flag', name: 'Marruecos', tag: 'marruecos', flag: '🇲🇦' %}
          {% render 'baul-mundial-flag', name: 'Senegal', tag: 'senegal', flag: '🇸🇳' %}
          {% render 'baul-mundial-flag', name: 'Sudáfrica', tag: 'sudafrica', flag: '🇿🇦' %}
          {% render 'baul-mundial-flag', name: 'Ghana', tag: 'ghana', flag: '🇬🇭' %}
          {% render 'baul-mundial-flag', name: 'Egipto', tag: 'egipto', flag: '🇪🇬' %}
          {% render 'baul-mundial-flag', name: 'Costa de Marfil', tag: 'costa-de-marfil', flag: '🇨🇮' %}
          {% render 'baul-mundial-flag', name: 'DR Congo', tag: 'congo', flag: '🇨🇩' %}
          {% render 'baul-mundial-flag', name: 'Cabo Verde', tag: 'cabo-verde', flag: '🇨🇻' %}
        </ul>
      </article>

      <article class="bm-continent rev">
        <h2 class="bm-continent-title">Asia y Oceanía</h2>
        <ul class="bm-flag-grid">
          {% render 'baul-mundial-flag', name: 'Japón', tag: 'japon', flag: '🇯🇵' %}
          {% render 'baul-mundial-flag', name: 'Corea del Sur', tag: 'corea-del-sur', flag: '🇰🇷' %}
          {% render 'baul-mundial-flag', name: 'Australia', tag: 'australia', flag: '🇦🇺' %}
          {% render 'baul-mundial-flag', name: 'Arabia Saudí', tag: 'arabia-saudi', flag: '🇸🇦' %}
          {% render 'baul-mundial-flag', name: 'Irán', tag: 'iran', flag: '🇮🇷' %}
          {% render 'baul-mundial-flag', name: 'Qatar', tag: 'qatar', flag: '🇶🇦' %}
          {% render 'baul-mundial-flag', name: 'Uzbekistán', tag: 'uzbekistan', flag: '🇺🇿' %}
          {% render 'baul-mundial-flag', name: 'Jordania', tag: 'jordania', flag: '🇯🇴' %}
          {% render 'baul-mundial-flag', name: 'Irak', tag: 'irak', flag: '🇮🇶' %}
          {% render 'baul-mundial-flag', name: 'Nueva Zelanda', tag: 'nueva-zelanda', flag: '🇳🇿' %}
          {% render 'baul-mundial-flag', name: 'Túnez', tag: 'tunez', flag: '🇹🇳' %}
          {% render 'baul-mundial-flag', name: 'Curazao', tag: 'curazao', flag: '🇨🇼' %}
          {% render 'baul-mundial-flag', name: 'Argelia', tag: 'argelia', flag: '🇩🇿' %}
          {% render 'baul-mundial-flag', name: 'Turquía', tag: 'turquia', flag: '🇹🇷' %}
        </ul>
      </article>
    </div>
  </div>
</section>

<script src="{{ 'baul-mundial.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Baúl Mundial 2026",
  "tag": "section",
  "class": "baul-mundial-section",
  "settings": [
    {
      "type": "header",
      "content": "Barra superior"
    },
    {
      "type": "text",
      "id": "countdown_text",
      "label": "Texto countdown",
      "default": "ENVÍO GRATIS POR TIEMPO LIMITADO — TERMINA EN:"
    },
    {
      "type": "text",
      "id": "promo_text",
      "label": "Banner promo",
      "default": "🎽 Lleva 3 camisetas y te llevas la 4ª a mitad de precio 🔥"
    },
    {
      "type": "header",
      "content": "Navbar"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo_secundario",
      "label": "Imagen junto al logo"
    },
    {
      "type": "header",
      "content": "Hero Mundial"
    },
    {
      "type": "image_picker",
      "id": "mundial_logo",
      "label": "Logo del Mundial"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Título",
      "default": "FIFA WORLD CUP 2026"
    },
    {
      "type": "text",
      "id": "hero_subtitle",
      "label": "Subtítulo",
      "default": "USA · CANADÁ · MÉXICO — 48 SELECCIONES"
    }
  ],
  "presets": [
    {
      "name": "Baúl Mundial 2026"
    }
  ]
}
{% endschema %}
