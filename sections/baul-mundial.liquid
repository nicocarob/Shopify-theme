<section class="bm-products col-sec" id="bm-products" hidden>
  <div class="sec-bg-grid"></div>
  <div class="bm-products-inner">
    <div class="sec-hdr rev sec-hdr--center">
      <h2 class="sec-title" id="bm-products-title">CAMISETAS</h2>
    </div>
    <div class="prod-grid" id="bm-products-grid">
      {% for product in collection.products %}
        {% liquid
          assign tag_slugs = ''
          for tag in product.tags
            assign tag_norm = tag | downcase | handleize
            if tag_slugs == blank
              assign tag_slugs = tag_norm
            else
              assign tag_slugs = tag_slugs | append: '|' | append: tag_norm
            endif
          endfor
        %}
        <div class="bm-product-item" data-tags="{{ tag_slugs }}">
          {% render 'baul-product-card', product: product %}
        </div>
      {% endfor %}
    </div>
    <p class="bm-empty" id="bm-empty" hidden>No hay camisetas para esta selección.</p>
    <div class="bm-products-actions">
      <button type="button" class="btn-v" id="bm-clear-all">Ver todos</button>
    </div>
  </div>
</section>

<script src="{{ 'baul-mundial.js' | asset_url }}" defer></script>

{% render 'baul-footer', section: section %}

{% schema %}
{
  "name": "Baúl Mundial 2026",
  "tag": "section",
  "class": "baul-mundial-section",
  "settings": [
    {
      "type": "header",
      "content": "Barra superior"
    },
    {
      "type": "text",
      "id": "countdown_text",
      "label": "Texto countdown",
      "default": "ENVÍO GRATIS POR TIEMPO LIMITADO — TERMINA EN:"
    },
    {
      "type": "text",
      "id": "promo_text",
      "label": "Banner promo",
      "default": "🎽 Lleva 3 camisetas y te llevas la 4ª a mitad de precio 🔥"
    },
    {
      "type": "header",
      "content": "Navbar"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo_secundario",
      "label": "Imagen junto al logo"
    },
    {
      "type": "header",
      "content": "Hero Mundial"
    },
    {
      "type": "image_picker",
      "id": "mundial_logo",
      "label": "Logo del Mundial"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Título",
      "default": "FIFA WORLD CUP 2026"
    },
    {
      "type": "text",
      "id": "hero_subtitle",
      "label": "Subtítulo",
      "default": "USA · CANADÁ · MÉXICO — 48 SELECCIONES · 12 GRUPOS"
    }
  ],
  "presets": [
    {
      "name": "Baúl Mundial 2026"
    }
  ]
}
{% endschema %}
