          <button type="button" class="bm-country" data-tag="bosnia" data-name="Bosnia" data-flag="🇧🇦"><span class="bm-flag">🇧🇦</span><span class="bm-country-name">Bosnia</span><span class="bm-arrow">→</span></button>
