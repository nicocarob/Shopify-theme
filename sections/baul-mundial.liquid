{% comment %}
  Copa del Mundo 2026 — Colección personalizada con grupos y filtro por país
{% endcomment %}

{% liquid
  assign hero_title = section.settings.hero_title | default: 'FIFA WORLD CUP 2026'
  assign hero_subtitle = section.settings.hero_subtitle | default: 'USA · CANADÁ · MÉXICO — 48 SELECCIONES · 12 GRUPOS'
  assign mundial_logo = section.settings.mundial_logo
%}

{% render 'baul-header', section: section %}

<section class="bm-hero">
  <div class="bm-hero-radial"></div>
  <div class="bm-particles" aria-hidden="true">
    {% for i in (1..10) %}
      <span class="bm-particle bm-particle--{{ i }}"></span>
    {% endfor %}
  </div>
  <div class="bm-hero-inner rev">
    {% if mundial_logo != blank %}
      <img
        class="bm-logo"
        src="{{ mundial_logo | image_url: width: 400 }}"
        alt="{{ mundial_logo.alt | default: 'Logo Copa del Mundo' | escape }}"
        width="200"
        height="200"
        loading="eager"
      >
    {% endif %}
    <span class="bm-badge">Copa del Mundo 2026</span>
    <h1 class="bm-title">
      {% if hero_title contains '2026' %}
        {% assign title_parts = hero_title | split: '2026' %}
        {{- title_parts[0] -}}<em>2026</em>{{- title_parts[1] -}}
      {% else %}
        {{ hero_title }}
      {% endif %}
    </h1>
    <p class="bm-subtitle">{{ hero_subtitle }}</p>
    <div class="bm-divider"></div>
    <p class="bm-hint">Selecciona tu selección para ver la colección</p>
  </div>
</section>

<section class="bm-groups" id="bm-groups">
  <div class="sec-bg-grid"></div>
  <div class="bm-groups-inner">
    <div class="bm-filter-banner" id="bm-filter-banner" hidden>
      <span class="bm-filter-flag" id="bm-filter-flag"></span>
      <span class="bm-filter-name" id="bm-filter-name"></span>
      <button type="button" class="bm-filter-clear" id="bm-filter-clear">Ver todos los grupos</button>
    </div>

    <div class="bm-group-grid" id="bm-group-grid">
      <div class="bm-group-card" style="--bm-delay: 0ms">
        <div class="bm-group-hdr">GRUPO A</div>
        <div class="bm-group-body">
          <button type="button" class="bm-country" data-tag="mexico" data-name="México" data-flag="🇲🇽"><span class="bm-flag">🇲🇽</span><span class="bm-country-name">México</span><span class="bm-arrow">→</span></button>
          <button type="button" class="bm-country" data-tag="sudafrica" data-name="Sudáfrica" data-flag="🇿🇦"><span class="bm-flag">🇿🇦</span><span class="bm-country-name">Sudáfrica</span><span class="bm-arrow">→</span></button>
          <button type="button" class="bm-country" data-tag="corea-del-sur" data-name="Corea del Sur" data-flag="🇰🇷"><span class="bm-flag">🇰🇷</span><span class="bm-country-name">Corea del Sur</span><span class="bm-arrow">→</span></button>
          <button type="button" class="bm-country" data-tag="chequia" data-name="Chequia" data-flag="🇨🇿"><span class="bm-flag">🇨🇿</span><span class="bm-country-name">Chequia</span><span class="bm-arrow">→</span></button>
        </div>
      </div>
