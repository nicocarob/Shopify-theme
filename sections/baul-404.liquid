{% comment %}
  Página 404 — La Cábala
{% endcomment %}

{% render 'baul-header', section: section %}

<section class="b404-page">
  <div class="sec-bg-grid"></div>
  <div class="b404-content rev">
    <h1 class="b404-title">404</h1>
    <p class="b404-subtitle">Página no encontrada</p>
    <a href="{{ routes.root_url }}" class="btn-green b404-btn">Volver al inicio</a>
  </div>
</section>

{% render 'baul-footer', section: section %}

{% schema %}
{
  "name": "Baúl 404",
  "tag": "section",
  "class": "baul-404-section",
  "settings": [
    {
      "type": "header",
      "content": "Barra superior"
    },
    {
      "type": "text",
      "id": "countdown_text",
      "label": "Texto countdown",
      "default": "ENVÍO GRATIS POR TIEMPO LIMITADO — TERMINA EN:"
    },
    {
      "type": "text",
      "id": "promo_text",
      "label": "Banner promo",
      "default": "🎽 Lleva 3 camisetas y te llevas la 4ª a mitad de precio 🔥"
    },
    {
      "type": "header",
      "content": "Navbar"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo_secundario",
      "label": "Imagen junto al logo"
    }
  ]
}
{% endschema %}
