{% comment %}
  La Cábala — Homepage completa
  Réplica visual del HTML de referencia con productos Shopify
{% endcomment %}

{% liquid
  assign logo_img = section.settings.logo
  if logo_img == blank
    assign logo_src = 'baul-logo.png' | asset_url
  else
    assign logo_src = logo_img | image_url: width: 104
  endif

  assign trophy_img = section.settings.trophy_image
  if trophy_img == blank
    assign trophy_src = 'baul-trophy.png' | asset_url
  else
    assign trophy_src = trophy_img | image_url: width: 800
  endif

  assign mv_collection = collections[section.settings.mv_collection]
  if mv_collection != blank and mv_collection.products_count > 0
    assign mv_products = mv_collection.products
  else
    assign mv_products = collections.all.products
  endif

  assign wc_collection = collections[section.settings.wc_collection]
  if wc_collection != blank and wc_collection.products_count > 0
    assign wc_products = wc_collection.products
  else
    assign wc_products = collections.all.products
  endif

  assign retro_collection = collections[section.settings.retro_collection]
  if retro_collection != blank and retro_collection.products_count > 0
    assign retro_products = retro_collection.products
  else
    assign retro_products = collections.all.products
  endif

  assign ninos_collection = collections[section.settings.ninos_collection]
  if ninos_collection != blank and ninos_collection.products_count > 0
    assign ninos_products = ninos_collection.products
  else
    assign ninos_products = collections.all.products
  endif

  assign fem_collection = collections[section.settings.fem_collection]
  if fem_collection != blank and fem_collection.products_count > 0
    assign fem_products = fem_collection.products
  else
    assign fem_products = collections.all.products
  endif

  assign wa_url = section.settings.whatsapp_url
  if wa_url == blank
    assign wa_url = 'https://wa.me/56951543485'
  endif
%}

<div id="cbar">
  <div class="cbar-line cbar-line--text">
    <span>🔥</span>
    <span class="cbar-text">{{ section.settings.countdown_text }}</span>
  </div>
  <div class="cbar-line cbar-line--timer">
    <span class="ctimer" id="mainTimer">05:00:00</span>
    <span class="cb-pill">📦 GRATIS A TODO CHILE</span>
  </div>
</div>

<div class="ticker">
  <div class="tick-tr">
    {% for i in (1..2) %}
      <span class="tick-it"><b>⚽</b>ENVÍO GRATIS A TODO CHILE</span>
      <span class="tick-it"><b>🎽</b>PERSONALIZA TU CAMISETA</span>
      <span class="tick-it"><b>⭐</b>MÁS DE 10 AÑOS DE EXPERIENCIA</span>
      <span class="tick-it"><b>🔥</b>LLEVA 3, LA 4ª A MITAD DE PRECIO</span>
      <span class="tick-it"><b>🏆</b>COPA DEL MUNDO 2026</span>
    {% endfor %}
  </div>
</div>

<div class="promo-banner">
  <p>{{ section.settings.promo_text }}</p>
</div>

<nav>
  <a class="n-logo" href="{{ routes.root_url }}">
    <img src="{{ logo_src }}" alt="{{ shop.name | escape }}" width="52" height="52">
    {% if section.settings.logo_secundario != blank %}
      <img
        class="n-logo-sec"
        src="{{ section.settings.logo_secundario | image_url: height: 80 }}"
        alt=""
        width="40"
        height="40"
        loading="lazy"
      >
    {% endif %}
    <span class="n-brand">LA CÁBALA</span>
  </a>
  <input type="checkbox" id="n-toggle" class="n-toggle" hidden>
  <label for="n-toggle" class="n-hamburger" aria-label="Abrir menú de navegación">☰</label>
  <ul class="n-links">
    <li><a href="{{ collections['liga-chilena'].url | default: '/collections/liga-chilena' }}">🇨🇱 Liga Chilena</a></li>
    <li><a href="{{ collections['liga-espanola'].url | default: '/collections/liga-espanola' }}">🇪🇸 Española</a></li>
    <li><a href="{{ collections['premier-league'].url | default: '/collections/premier-league' }}">🏴󠁧󠁢󠁥󠁮󠁧󠁿 Premier</a></li>
    <li><a href="{{ collections['selecciones'].url | default: '/collections/selecciones' }}">🌍 Selecciones</a></li>
    <li><a href="{{ collections['retro'].url | default: '/collections/retro' }}">🕰️ Retro</a></li>
    <li><a href="{{ collections['ninos'].url | default: '/collections/ninos' }}">👦 Niños</a></li>
    <li><a href="{{ collections['mujer'].url | default: '/collections/mujer' }}">👩 Mujer</a></li>
  </ul>
  <a href="{{ routes.cart_url }}" class="btn-cart" style="text-decoration:none;">🛒 Carrito ({{ cart.item_count }})</a>
</nav>

<section class="hero">
  <div class="sec-bg-grid"></div>
  <div class="sec-bg-light"></div>
  <div class="hero-grid">
    <div class="rev-l">
      <div class="hero-tag"><span>🏆 {{ section.settings.hero_tag }}</span></div>
      <h1 class="hero-title">COPA<br>DEL<br>MUNDO<br><em>{{ section.settings.hero_year }}</em></h1>
      <div class="hero-sub-line">{{ section.settings.hero_subtitle }}</div>
      <p class="hero-desc">{{ section.settings.hero_description }}</p>
      <div class="hero-btns">
        <a href="#colsec" class="btn-gold">{{ section.settings.hero_btn_primary }}</a>
        <a href="#buscar" class="btn-ghost">{{ section.settings.hero_btn_secondary }}</a>
      </div>
      <div class="hero-flags">
        <span class="flag-b">🇨🇱</span><span class="flag-b">🇦🇷</span><span class="flag-b">🇧🇷</span>
        <span class="flag-b">🇵🇹</span><span class="flag-b">🇩🇪</span><span class="flag-b">🇫🇷</span>
        <span class="flag-b">🇪🇸</span><span class="flag-b">🏴󠁧󠁢󠁥󠁮󠁧󠁿</span>
      </div>
    </div>
    <div class="hero-r rev-r">
      <div class="trophy-scene">
        <div class="trophy-glow"></div>
        <div class="trophy-shadow"></div>
        <div class="spark s1"></div><div class="spark s2"></div>
        <div class="spark s3"></div><div class="spark s4"></div>
        <div class="spark s5"></div><div class="spark s6"></div>
        <img class="trophy-img" src="{{ trophy_src }}" alt="Copa del Mundo FIFA" width="320" height="420" loading="eager">
      </div>
    </div>
  </div>
</section>

<section class="testi-sec">
  <div class="sec-bg-grid"></div>
  <div class="sec-bg-light"></div>
  <div class="testi-hdr rev">
    <div class="eyebrow">{{ section.settings.testi_eyebrow }}</div>
    <h2 class="sec-title">{{ section.settings.testi_title }}</h2>
    <p class="sec-sub" style="margin-top:8px;">{{ section.settings.testi_subtitle }}</p>
  </div>
  <div class="testi-wrap">
    <div class="testi-track">
      {% for block in section.blocks %}
        {% if block.type == 'testimonial' and block.settings.image != blank %}
          <div class="t-card" {{ block.shopify_attributes }}>
            <img
              class="t-img"
              src="{{ block.settings.image | image_url: width: 520 }}"
              alt="{{ block.settings.image.alt | default: 'Cliente' | escape }}"
              width="260"
              height="460"
              loading="lazy"
            >
          </div>
        {% endif %}
      {% endfor %}
      {% comment %} Duplicar para loop infinito del carrusel {% endcomment %}
      {% for block in section.blocks %}
        {% if block.type == 'testimonial' and block.settings.image != blank %}
          <div class="t-card" aria-hidden="true">
            <img
              class="t-img"
              src="{{ block.settings.image | image_url: width: 520 }}"
              alt=""
              width="260"
              height="460"
              loading="lazy"
            >
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<section class="mv-sec" id="vendidos">
  <div class="sec-bg-grid"></div>
  <div class="sec-hdr rev">
    <div>
      <div class="eyebrow">Lo que todos quieren</div>
      <h2 class="sec-title">MÁS VENDIDOS</h2>
      <div class="sec-sub">Las camisetas favoritas de nuestros hinchas</div>
    </div>
    <a href="{{ section.settings.mv_collection_url | default: routes.all_products_collection_url }}" class="lk-all">Ver todo →</a>
  </div>
  <div class="prod-grid">
    {% for product in mv_products limit: 4 %}
      {% case forloop.index0 %}
        {% when 1 %}{% assign delay_val = '0.07s' %}
        {% when 2 %}{% assign delay_val = '0.14s' %}
        {% when 3 %}{% assign delay_val = '0.21s' %}
        {% else %}{% assign delay_val = '' %}
      {% endcase %}
      {% render 'baul-product-card',
        product: product,
        rank: forloop.index,
        show_urgency: true,
        timer_idx: forloop.index0,
        delay: delay_val
      %}
    {% endfor %}
  </div>
</section>

<div class="divider"></div>

<section class="srch-sec" id="buscar">
  <div class="rev sec-hdr--center" style="text-align:center;">
    <div class="eyebrow">Encuentra tu camiseta</div>
    <h2 class="sec-title">BUSCA POR EQUIPO O LIGA</h2>
    <form class="srch-box" id="baul-search-form" action="{{ routes.search_url }}" method="get" role="search">
      <input class="srch-in" type="search" name="q" placeholder="Ej: Real Madrid, Chile, Barcelona..." autocomplete="off">
      <button class="srch-btn" type="submit" aria-label="Buscar">🔍</button>
    </form>
  </div>
  <div class="liga-grid rev">
    {% for block in section.blocks %}
      {% if block.type == 'liga' %}
        {% assign liga_col = collections[block.settings.collection_handle] %}
        <a class="lg-c" href="{{ liga_col.url | default: '#' }}" {{ block.shopify_attributes }}>
          <div class="lg-circle">
            {% if block.settings.logo != blank %}
              <img
                src="{{ block.settings.logo | image_url: width: 120 }}"
                alt="{{ block.settings.liga_name | escape }}"
                width="60"
                height="60"
                style="width:60px;height:60px;object-fit:contain;"
              >
            {% else %}
              <div class="lg-ico">{{ block.settings.emoji | default: '⚽' }}</div>
            {% endif %}
          </div>
          <div class="lg-nm">{{ block.settings.liga_name }}</div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</section>

<div class="divider"></div>

<section class="col-sec col-sec--gold" id="colsec">
  <div class="sec-bg-grid"></div>
  <div class="sec-bg-radial"></div>
  <div class="sec-hdr rev">
    <div>
      <div class="eyebrow">Colección especial</div>
      <h2 class="sec-title">FIFA WORLD CUP 2026</h2>
      <div class="sec-sub">Las camisetas del evento más grande del fútbol</div>
    </div>
    <a href="{{ wc_collection.url | default: section.settings.wc_collection_url }}" class="lk-all">Ver toda →</a>
  </div>
  <div class="prod-grid">
    {% for product in wc_products limit: 4 %}
      {% case forloop.index0 %}
        {% when 1 %}{% assign delay_val = '0.07s' %}
        {% when 2 %}{% assign delay_val = '0.14s' %}
        {% when 3 %}{% assign delay_val = '0.21s' %}
        {% else %}{% assign delay_val = '' %}
      {% endcase %}
      {% render 'baul-product-card', product: product, delay: delay_val %}
    {% endfor %}
  </div>
</section>

<div class="divider"></div>

<section class="col-sec">
  <div class="sec-bg-grid"></div>
  <div class="sec-hdr rev">
    <div>
      <div class="eyebrow">Los clásicos de siempre</div>
      <h2 class="sec-title">COLECCIÓN RETRO</h2>
      <div class="sec-sub">Las camisetas que marcaron historia</div>
    </div>
    <a href="{{ retro_collection.url | default: section.settings.retro_collection_url }}" class="lk-all">Ver toda →</a>
  </div>
  <div class="prod-grid">
    {% for product in retro_products limit: 4 %}
      {% case forloop.index0 %}
        {% when 1 %}{% assign delay_val = '0.07s' %}
        {% when 2 %}{% assign delay_val = '0.14s' %}
        {% when 3 %}{% assign delay_val = '0.21s' %}
        {% else %}{% assign delay_val = '' %}
      {% endcase %}
      {% render 'baul-product-card', product: product, delay: delay_val, version_text: 'Edición Retro' %}
    {% endfor %}
  </div>
</section>

<div class="divider"></div>

<section class="col-sec">
  <div class="sec-bg-grid"></div>
  <div class="sec-hdr rev">
    <div>
      <div class="eyebrow">Para los más chicos</div>
      <h2 class="sec-title">COLECCIÓN NIÑOS</h2>
      <div class="sec-sub">Talles 4 a 14 años disponibles</div>
    </div>
    <a href="{{ ninos_collection.url | default: section.settings.ninos_collection_url }}" class="lk-all">Ver toda →</a>
  </div>
  <div class="prod-grid">
    {% for product in ninos_products limit: 4 %}
      {% case forloop.index0 %}
        {% when 1 %}{% assign delay_val = '0.07s' %}
        {% when 2 %}{% assign delay_val = '0.14s' %}
        {% when 3 %}{% assign delay_val = '0.21s' %}
        {% else %}{% assign delay_val = '' %}
      {% endcase %}
      {% render 'baul-product-card', product: product, delay: delay_val, version_text: 'Tallas 4–14 años' %}
    {% endfor %}
  </div>
</section>

<div class="divider"></div>

<section class="col-sec col-sec--pink">
  <div class="sec-bg-grid"></div>
  <div class="sec-hdr rev">
    <div>
      <div class="eyebrow">Para ellas</div>
      <h2 class="sec-title">COLECCIÓN FEMENINA</h2>
      <div class="sec-sub">Corte y talla femenina, mismo estilo premium</div>
    </div>
    <a href="{{ fem_collection.url | default: section.settings.fem_collection_url }}" class="lk-all">Ver toda →</a>
  </div>
  <div class="prod-grid">
    {% for product in fem_products limit: 4 %}
      {% case forloop.index0 %}
        {% when 1 %}{% assign delay_val = '0.07s' %}
        {% when 2 %}{% assign delay_val = '0.14s' %}
        {% when 3 %}{% assign delay_val = '0.21s' %}
        {% else %}{% assign delay_val = '' %}
      {% endcase %}
      {% render 'baul-product-card', product: product, delay: delay_val, version_text: 'Corte Mujer' %}
    {% endfor %}
  </div>
</section>

<footer>
  <div class="ft-grid">
    <div>
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
        <img src="{{ logo_src }}" style="width:44px;height:44px;object-fit:contain;" alt="{{ shop.name | escape }}" width="44" height="44">
        <span style="font-family:'Bebas Neue',sans-serif;font-size:26px;color:#fff;letter-spacing:.05em;">LA CÁBALA</span>
      </div>
      <p class="ft-desc">{{ section.settings.footer_description }}</p>
      <div class="ft-soc">
        {% if section.settings.instagram_url != blank %}
          <a class="ft-s" href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener">📸</a>
        {% endif %}
        <a class="ft-s" href="{{ wa_url }}" target="_blank" rel="noopener">💬</a>
      </div>
    </div>
    <div>
      <div class="ft-col-t">Ligas</div>
      <ul class="ft-links">
        <li><a href="{{ collections['liga-chilena'].url | default: '#' }}">Liga Chilena</a></li>
        <li><a href="{{ collections['liga-espanola'].url | default: '#' }}">Liga Española</a></li>
        <li><a href="{{ collections['premier-league'].url | default: '#' }}">Premier League</a></li>
        <li><a href="{{ collections['serie-a'].url | default: '#' }}">Serie A</a></li>
        <li><a href="{{ collections['selecciones'].url | default: '#' }}">Selecciones</a></li>
      </ul>
    </div>
    <div>
      <div class="ft-col-t">Colecciones</div>
      <ul class="ft-links">
        <li><a href="#colsec">Copa del Mundo 2026</a></li>
        <li><a href="{{ collections['retro'].url | default: '#' }}">Retro</a></li>
        <li><a href="{{ collections['ninos'].url | default: '#' }}">Niños</a></li>
        <li><a href="{{ collections['mujer'].url | default: '#' }}">Femenino</a></li>
        <li><a href="{{ collections['liquidacion'].url | default: '#' }}">Liquidación</a></li>
      </ul>
    </div>
    <div>
      <div class="ft-col-t">Ayuda</div>
      <ul class="ft-links">
        <li><a href="{{ pages['politica-de-envios'].url | default: '/pages/politica-de-envios' }}">Política de envíos</a></li>
        <li><a href="{{ pages['devoluciones'].url | default: '/pages/devoluciones' }}">Devoluciones</a></li>
        <li><a href="{{ pages['guia-de-tallas'].url | default: '/pages/guia-de-tallas' }}">Guía de tallas</a></li>
        <li><a href="{{ pages['personalizacion'].url | default: '/pages/personalizacion' }}">Personalización</a></li>
        <li><a href="{{ wa_url }}" target="_blank" rel="noopener">WhatsApp</a></li>
      </ul>
    </div>
  </div>
  <div class="ft-bot">
    <span class="ft-copy">© {{ 'now' | date: '%Y' }} La Cábala — Todos los derechos reservados</span>
    <span class="ft-copy">Hecho con ⚽ en Chile</span>
  </div>
</footer>

<a class="wa" href="{{ wa_url }}" target="_blank" rel="noopener" aria-label="WhatsApp">💬</a>

