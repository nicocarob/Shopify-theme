{% comment %}
  Seccion Cortavientos Edicion Limitada
  Archivo: sections/cortavientos-limitados.liquid
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@400;600;700;900&display=swap" rel="stylesheet">

<style>
  .cw-section-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px 20px;
    position: relative;
    overflow: hidden;
  }

  /* Fondo */
  .cw-bg-{{ section.id }} {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    z-index: 0;
  }

  .cw-light-{{ section.id }} {
    position: absolute;
    top: -80px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(255,255,255,0.04) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* Header */
  .cw-header-{{ section.id }} {
    text-align: center;
    margin-bottom: 32px;
    position: relative;
    z-index: 1;
  }

  /* Tag edicion limitada */
  .cw-tag-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    color: #000;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 14px;
    letter-spacing: 3px;
    padding: 6px 20px;
    border-radius: 4px;
    margin-bottom: 14px;
    box-shadow: 0 4px 20px rgba(255,255,255,0.15);
  }

  .cw-tag-dot-{{ section.id }} {
    width: 7px;
    height: 7px;
    background: #ff4444;
    border-radius: 50%;
    animation: cwDot_{{ section.id }} 1s ease-in-out infinite;
  }

  @keyframes cwDot_{{ section.id }} {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.3; transform: scale(0.7); }
  }

  .cw-title-{{ section.id }} {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(44px, 7vw, 88px);
    letter-spacing: 3px;
    color: #fff;
    margin: 0 0 6px 0;
    line-height: 0.95;
  }

  .cw-title-{{ section.id }} span {
    -webkit-text-stroke: 2px #fff;
    color: transparent;
  }

  .cw-subtitle-{{ section.id }} {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: rgba(255,255,255,0.4);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin: 0;
  }

  /* Chips info */
  .cw-chips-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 14px;
  }

  .cw-chip-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 20px;
  }

  .cw-chip-white-{{ section.id }} {
    color: #fff;
    border: 1px solid rgba(255,255,255,0.25);
    background: rgba(255,255,255,0.06);
  }

  .cw-chip-red-{{ section.id }} {
    color: #ff4444;
    border: 1px solid rgba(255,60,60,0.3);
    background: rgba(255,60,60,0.08);
  }

  /* Grid */
  .cw-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.cols_desktop }}, 1fr);
    gap: {{ section.settings.gap }}px;
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* Tarjeta */
  .cw-card-{{ section.id }} {
    background: #111;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    position: relative;
  }

  .cw-card-{{ section.id }}:hover {
    transform: translateY(-6px);
    border-color: rgba(255,255,255,0.5);
    box-shadow: 0 20px 50px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.3);
    text-decoration: none;
  }

  /* Imagen */
  .cw-img-wrap-{{ section.id }} {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #1a1a1a;
  }

  .cw-img-{{ section.id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .cw-card-{{ section.id }}:hover .cw-img-{{ section.id }} {
    transform: scale(1.04);
  }

  /* Overlay gradiente */
  .cw-img-overlay-{{ section.id }} {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 55%);
    z-index: 1;
  }

  /* Badge numero limitado */
  .cw-badge-num-{{ section.id }} {
    position: absolute;
    top: 14px;
    right: 14px;
    background: #fff;
    color: #000;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 13px;
    letter-spacing: 1px;
    padding: 4px 12px;
    border-radius: 4px;
    z-index: 2;
  }

  /* Badge edicion limitada */
  .cw-badge-lim-{{ section.id }} {
    position: absolute;
    top: 14px;
    left: 14px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 4px;
    z-index: 2;
  }

  /* Barra de stock */
  .cw-stock-wrap-{{ section.id }} {
    position: absolute;
    bottom: 14px;
    left: 14px;
    right: 14px;
    z-index: 2;
  }

  .cw-stock-label-{{ section.id }} {
    display: flex;
    justify-content: space-between;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    font-weight: 700;
    color: rgba(255,255,255,0.7);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 5px;
  }

  .cw-stock-label-{{ section.id }} span:last-child { color: #ff6644; }

  .cw-stock-track-{{ section.id }} {
    height: 4px;
    background: rgba(255,255,255,0.15);
    border-radius: 2px;
    overflow: hidden;
  }

  .cw-stock-fill-{{ section.id }} {
    height: 100%;
    border-radius: 2px;
    background: linear-gradient(to right, #ff4444, #ff8800);
    animation: cwFill_{{ section.id }} 1.5s ease-out forwards;
  }

  @keyframes cwFill_{{ section.id }} { from { width: 0%; } }

  /* Info */
  .cw-info-{{ section.id }} {
    padding: 16px 18px 18px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .cw-name-{{ section.id }} {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 17px;
    font-weight: 700;
    color: #fff;
    margin: 0 0 3px 0;
    line-height: 1.2;
  }

  .cw-sub-{{ section.id }} {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: rgba(255,255,255,0.35);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin: 0 0 12px 0;
  }

  .cw-bottom-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-top: auto;
  }

  .cw-prices-{{ section.id }} { display: flex; flex-direction: column; gap: 1px; }

  .cw-compare-{{ section.id }} {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    color: rgba(255,255,255,0.3);
    text-decoration: line-through;
    font-weight: 600;
  }

  .cw-price-{{ section.id }} {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    color: #fff;
    line-height: 1;
  }

  .cw-btn-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: #fff !important;
    color: #000 !important;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 14px;
    letter-spacing: 1.5px;
    padding: 10px 18px;
    border-radius: 6px;
    flex-shrink: 0;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .cw-btn-{{ section.id }}:hover {
    background: #ddd !important;
    transform: scale(1.04);
    color: #000 !important;
  }

  .cw-btn-{{ section.id }} svg { width: 13px; height: 13px; }

  /* Nota al pie */
  .cw-footer-{{ section.id }} {
    text-align: center;
    margin-top: 28px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: rgba(255,255,255,0.2);
    letter-spacing: 2px;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
  }

  /* Boton ver todos */
  .cw-cta-wrap-{{ section.id }} {
    text-align: center;
    margin-top: 32px;
    position: relative;
    z-index: 1;
  }

  .cw-cta-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 2px;
    color: #000;
    background: #fff;
    padding: 14px 44px;
    border-radius: 4px;
    text-decoration: none;
    box-shadow: 0 6px 24px rgba(255,255,255,0.15);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .cw-cta-{{ section.id }}:hover {
    background: #ddd;
    transform: translateY(-2px);
    text-decoration: none;
    color: #000;
  }

  .cw-cta-{{ section.id }} svg { width: 16px; height: 16px; }

  /* Responsive */
  @media (max-width: 900px) {
    .cw-grid-{{ section.id }} { grid-template-columns: repeat({{ section.settings.cols_tablet }}, 1fr); }
  }

  @media (max-width: 560px) {
    .cw-grid-{{ section.id }} { grid-template-columns: repeat(2, 1fr); gap: 10px; }
    .cw-info-{{ section.id }} { padding: 12px; }
    .cw-btn-{{ section.id }} { padding: 8px 12px; }
    .cw-cta-{{ section.id }} { width: 90%; justify-content: center; }
  }
</style>

<section class="cw-section-{{ section.id }}">
  <div class="cw-bg-{{ section.id }}"></div>
  <div class="cw-light-{{ section.id }}"></div>

  <!-- Header -->
  <div class="cw-header-{{ section.id }}">
    <div class="cw-tag-{{ section.id }}">
      <span class="cw-tag-dot-{{ section.id }}"></span>
      {{ section.settings.tag_text }}
    </div>
    <h2 class="cw-title-{{ section.id }}">
      {{ section.settings.title_before }}
      {% if section.settings.title_outline != blank %}
        <span>{{ section.settings.title_outline }}</span>
      {% endif %}
    </h2>
    {% if section.settings.subtitle != blank %}
      <p class="cw-subtitle-{{ section.id }}">{{ section.settings.subtitle }}</p>
    {% endif %}
    <div class="cw-chips-{{ section.id }}">
      <span class="cw-chip-{{ section.id }} cw-chip-white-{{ section.id }}">
        🧥 {{ section.settings.chip_units }}
      </span>
      <span class="cw-chip-{{ section.id }} cw-chip-red-{{ section.id }}">
        ⚡ {{ section.settings.chip_urgency }}
      </span>
    </div>
  </div>

  <!-- Grid -->
  <div class="cw-grid-{{ section.id }}">
    {%- for block in section.blocks -%}
      {%- assign prod = block.settings.product -%}
      <a class="cw-card-{{ section.id }}" href="{{ prod.url | default: '#' }}" {{ block.shopify_attributes }}>

        <div class="cw-img-wrap-{{ section.id }}">
          {%- if prod.featured_image != blank -%}
            <img
              class="cw-img-{{ section.id }}"
              src="{{ prod.featured_image | img_url: '700x' }}"
              alt="{{ prod.title }}"
              loading="lazy"
            >
          {%- endif -%}
          <div class="cw-img-overlay-{{ section.id }}"></div>

          <div class="cw-badge-lim-{{ section.id }}">
            🔒 {{ block.settings.badge_text }}
          </div>

          {% if block.settings.units_left != blank %}
            <div class="cw-badge-num-{{ section.id }}">{{ block.settings.units_left }}</div>
          {% endif %}

          {% if block.settings.show_stock_bar %}
            <div class="cw-stock-wrap-{{ section.id }}">
              <div class="cw-stock-label-{{ section.id }}">
                <span>Stock</span>
                <span>{{ block.settings.stock_text }}</span>
              </div>
              <div class="cw-stock-track-{{ section.id }}">
                <div class="cw-stock-fill-{{ section.id }}" style="width:{{ block.settings.stock_percent }}%"></div>
              </div>
            </div>
          {% endif %}
        </div>

        <div class="cw-info-{{ section.id }}">
          <p class="cw-name-{{ section.id }}">{{ prod.title }}</p>
          {% if block.settings.subtitle != blank %}
            <p class="cw-sub-{{ section.id }}">{{ block.settings.subtitle }}</p>
          {% endif %}

          <div class="cw-bottom-{{ section.id }}">
            <div class="cw-prices-{{ section.id }}">
              {%- if prod.compare_at_price > prod.price -%}
                <span class="cw-compare-{{ section.id }}">{{ prod.compare_at_price | money }}</span>
              {%- endif -%}
              <span class="cw-price-{{ section.id }}">{{ prod.price | money }}</span>
            </div>
            <span class="cw-btn-{{ section.id }}">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
              </svg>
              Ver
            </span>
          </div>
        </div>
      </a>
    {%- endfor -%}
  </div>

  {% if section.settings.cta_url != blank %}
    <div class="cw-cta-wrap-{{ section.id }}">
      <a href="{{ section.settings.cta_url }}" class="cw-cta-{{ section.id }}">
        {{ section.settings.cta_text }}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>
  {% endif %}

  <p class="cw-footer-{{ section.id }}">{{ section.settings.footer_text }}</p>

</section>


{% schema %}
{
  "name": "Cortavientos Limitados",
  "tag": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Encabezado"
    },
    {
      "type": "text",
      "id": "tag_text",
      "label": "Tag superior",
      "default": "Edicion Limitada"
    },
    {
      "type": "text",
      "id": "title_before",
      "label": "Titulo solido",
      "default": "Solo"
    },
    {
      "type": "text",
      "id": "title_outline",
      "label": "Titulo outline (contorno)",
      "default": "50 Unidades"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitulo",
      "default": "Cortavientos de edicion limitada - Sin reposicion de stock"
    },
    {
      "type": "text",
      "id": "chip_units",
      "label": "Chip unidades",
      "default": "Solo 50 unidades disponibles"
    },
    {
      "type": "text",
      "id": "chip_urgency",
      "label": "Chip urgencia",
      "default": "Una vez agotado no vuelve"
    },
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fondo",
      "default": "#0A0A0A"
    },
    {
      "type": "header",
      "content": "Columnas"
    },
    {
      "type": "range",
      "id": "cols_desktop",
      "label": "Columnas desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "cols_tablet",
      "label": "Columnas tablet",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espacio entre tarjetas",
      "min": 8,
      "max": 40,
      "step": 4,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Boton ver todos"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Enlace del boton"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del boton",
      "default": "VER TODOS LOS CORTAVIENTOS"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Nota al pie",
      "default": "Stock limitado a 50 unidades por modelo - Sin reposicion"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "cortavientos",
      "name": "Cortavientos",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Producto"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitulo",
          "default": "Edicion Limitada - 50 unidades"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge superior izquierda",
          "default": "Edicion Limitada"
        },
        {
          "type": "text",
          "id": "units_left",
          "label": "Unidades restantes (badge derecha, ej: 12 left)",
          "default": "50 left"
        },
        {
          "type": "header",
          "content": "Barra de stock"
        },
        {
          "type": "checkbox",
          "id": "show_stock_bar",
          "label": "Mostrar barra de stock",
          "default": true
        },
        {
          "type": "range",
          "id": "stock_percent",
          "label": "Stock restante (%)",
          "min": 5,
          "max": 95,
          "step": 5,
          "default": 80
        },
        {
          "type": "text",
          "id": "stock_text",
          "label": "Texto de stock",
          "default": "40 de 50 disponibles"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cortavientos Limitados"
    }
  ]
}
{% endschema %}
