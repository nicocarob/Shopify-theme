{% comment %}
  Página de producto La Cábala
{% endcomment %}

{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign compare_at_price = current_variant.compare_at_price
  assign price = current_variant.price
  assign wa_url = 'https://wa.me/message/Z5XXALWPDL4GI1'

  if compare_at_price > price
    assign discount_amount = compare_at_price | minus: price
    assign discount_pct = discount_amount | times: 100 | divided_by: compare_at_price
  else
    assign discount_pct = 0
  endif

  assign vendor_label = product.vendor
  if vendor_label == blank
    assign vendor_label = product.type
  endif

  assign talla_tab = 'fan'
  if product.title contains 'Niño' or product.title contains 'niño' or product.title contains 'Nino' or product.title contains 'nino'
    assign talla_tab = 'ninos'
  elsif product.title contains 'Mujer' or product.title contains 'mujer'
    assign talla_tab = 'mujer'
  elsif product.title contains 'Player' or product.title contains 'player' or product.title contains 'PLAYER'
    assign talla_tab = 'jugador'
  elsif product.title contains 'Cortavientos' or product.title contains 'cortavientos' or product.title contains 'Chaqueta' or product.title contains 'chaqueta'
    assign talla_tab = 'cortavientos'
  endif
%}

{% render 'baul-header', section: section %}

<section class="bp-page">
  <div class="sec-bg-grid"></div>
  <div class="bp-grid">
    <div class="bp-gallery">
      <div class="bp-main-img-wrap">
        {% if product.featured_image %}
          <img
            id="bp-main-img"
            class="bp-main-img"
            src="{{ product.featured_image | image_url: width: 1200 }}"
            alt="{{ product.featured_image.alt | default: product.title | escape }}"
            width="800"
            height="800"
            loading="eager"
          >
        {% else %}
          <div class="pc-bg">⚽</div>
        {% endif %}
      </div>
      {% if product.images.size > 1 %}
        <div class="bp-thumbs">
          {% for image in product.images %}
            <button
              type="button"
              class="bp-thumb{% if forloop.first %} is-active{% endif %}"
              data-src="{{ image | image_url: width: 1200 }}"
              aria-label="Ver imagen {{ forloop.index }}"
            >
              <img
                src="{{ image | image_url: width: 200 }}"
                alt="{{ image.alt | default: product.title | escape }}"
                width="80"
                height="80"
                loading="lazy"
              >
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="bp-info">
      <div class="bp-badges">
        <span class="bp-badge-urgency">🔥 ÚLTIMAS UNIDADES</span>
        <span class="bp-badge-ship">ENVÍO GRATIS</span>
      </div>

      <h1 class="bp-title">{{ product.title }}</h1>
      <div class="product-stars product-stars--pdp" data-handle="{{ product.handle }}"></div>
      {% if vendor_label != blank or product.type != blank %}
        <p class="bp-subtitle">
          {% if product.vendor != blank %}{{ product.vendor }}{% endif %}
          {% if product.vendor != blank and product.type != blank %} · {% endif %}
          {% if product.type != blank %}{{ product.type }}{% endif %}
        </p>
      {% endif %}

      <div class="bp-price-row" id="bp-price-row">
        {% if compare_at_price > price %}
          <span class="p-old" id="bp-compare-price">{{ compare_at_price | money_without_trailing_zeros }}</span>
          <span class="p-new" id="bp-price">{{ price | money_without_trailing_zeros }}</span>
          <span class="bp-discount-badge">−{{ discount_pct }}%</span>
        {% else %}
          <span class="p-new" id="bp-price">{{ price | money_without_trailing_zeros }}</span>
        {% endif %}
      </div>

      <div class="bp-stock">
        <div class="urg-top">
          <div class="ult-dia">
            <div class="ult-dia-dot"></div>
            <span class="ult-dia-txt">ÚLTIMO DÍA — QUEDAN POCAS UNIDADES</span>
          </div>
        </div>
        <div class="urg-bar">
          <div class="urg-fill" style="width:28%;background:#ef4444;"></div>
        </div>
      </div>

      {% form 'product', product, id: 'baul-product-form', class: 'bp-form' %}
        <input type="hidden" name="id" id="baul-variant-id" value="{{ current_variant.id }}">

        {% unless product.has_only_default_variant %}
          {% for option in product.options_with_values %}
            <div class="bp-option">
              <div class="bp-option-label">{{ option.name }}</div>
              <div class="bp-variants" data-option-index="{{ forloop.index0 }}">
                {% for value in option.values %}
                  {% assign opt_available = false %}
                  {% for variant in product.variants %}
                    {% if option.position == 1 and variant.option1 == value and variant.available %}
                      {% assign opt_available = true %}
                    {% elsif option.position == 2 and variant.option2 == value and variant.available %}
                      {% assign opt_available = true %}
                    {% elsif option.position == 3 and variant.option3 == value and variant.available %}
                      {% assign opt_available = true %}
                    {% endif %}
                  {% endfor %}
                  <button
                    type="button"
                    class="bp-variant-btn{% if current_variant.options[forloop.parentloop.index0] == value %} is-active{% endif %}{% unless opt_available %} is-unavailable{% endunless %}"
                    data-option-index="{{ forloop.parentloop.index0 }}"
                    data-value="{{ value | escape }}"
                  >
                    {{ value }}
                  </button>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        {% endunless %}

        <button type="button" id="btn-tallas">
          📏 Guía de tallas
        </button>

        {% render 'easify-pof__product-option' %}

        <button type="submit" name="add" class="bp-atc" id="bp-atc-btn"{% unless current_variant.available %} disabled{% endunless %}>
          AGREGAR AL CARRO
        </button>
      {% endform %}

      <div class="bp-trust">
        <span>🚚 Envío gratis</span>
        <span>🔒 Pago seguro</span>
      </div>

      <div style="text-align:center; margin: 10px 0;">
        <img src="https://cdn.shopify.com/s/files/1/0801/5098/6775/files/242115f4-2632-44a9-a03a-b782812dbc6b.png?v=1782274379" alt="Medios de pago" style="max-width:380px; width:100%; height:auto; opacity:0.9;">
      </div>
    </div>
  </div>

  {% if product.description != blank %}
    <div class="bp-desc-wrap">
      <div class="bp-desc rte">
        {{ product.description }}
      </div>
    </div>
  {% endif %}

  {% liquid
    assign team_tag = ''
    assign skip_tags = 'adultos,ninos,niños,local,visitante,mujer,player-version,retro,mundial,cortavientos' | split: ','

    for tag in product.tags
      assign tag_key = tag | downcase | strip
      assign tag_handle = tag | handleize
      unless skip_tags contains tag_key
        assign is_season = false
        if tag_key contains '25-26' or tag_key contains '24-25' or tag_key contains '26-27'
          assign is_season = true
        endif
        unless is_season
          if collections[tag] != blank
            assign team_tag = tag_handle
            break
          elsif collections[tag_handle] != blank
            assign team_tag = tag_handle
            break
          elsif collections[tag_key] != blank
            assign team_tag = tag_key
            break
          endif
        endunless
      endunless
    endfor

    if team_tag == blank
      for tag in product.tags
        assign tag_key = tag | downcase | strip
        assign tag_handle = tag | handleize
        unless skip_tags contains tag_key
          assign is_season = false
          if tag_key contains '25-26' or tag_key contains '24-25' or tag_key contains '26-27'
            assign is_season = true
          endif
          if is_season == false and tag contains '-'
            assign team_tag = tag_handle
            break
          endif
        endunless
      endfor
    endif

    if team_tag == blank
      for tag in product.tags
        assign tag_key = tag | downcase | strip
        assign tag_handle = tag | handleize
        unless skip_tags contains tag_key
          if tag_handle.size > 2
            assign team_tag = tag_handle
            break
          endif
        endunless
      endfor
    endif

    assign shown = 0
    assign tag_count = 0
    assign shown_ids = ','
  %}

  {% capture related_cards %}
    {% if team_tag != blank %}
      {% for p in collections.all.products limit: 250 %}
        {% if p.tags contains team_tag and p.id != product.id %}
          {% assign pid_marker = ',' | append: p.id | append: ',' %}
          {% unless shown_ids contains pid_marker %}
            {% render 'baul-product-card', product: p %}
            {% assign shown = shown | plus: 1 %}
            {% assign tag_count = tag_count | plus: 1 %}
            {% assign shown_ids = shown_ids | append: p.id | append: ',' %}
            {% if shown >= 8 %}{% break %}{% endif %}
          {% endunless %}
        {% endif %}
      {% endfor %}
    {% endif %}

    {% if tag_count < 4 %}
      {% assign related_collection = product.collections.first %}
      {% if related_collection != blank %}
        {% for p in related_collection.products %}
          {% unless p.id == product.id %}
            {% if shown < 8 %}
              {% assign pid_marker = ',' | append: p.id | append: ',' %}
              {% unless shown_ids contains pid_marker %}
                {% render 'baul-product-card', product: p %}
                {% assign shown = shown | plus: 1 %}
                {% assign shown_ids = shown_ids | append: p.id | append: ',' %}
                {% if shown >= 8 %}{% break %}{% endif %}
              {% endunless %}
            {% endif %}
          {% endunless %}
        {% endfor %}
      {% endif %}
    {% endif %}

    {% if shown == 0 %}
      {% for p in collections.all.products limit: 8 %}
        {% unless p.id == product.id %}
          {% assign pid_marker = ',' | append: p.id | append: ',' %}
          {% unless shown_ids contains pid_marker %}
            {% render 'baul-product-card', product: p %}
            {% assign shown = shown | plus: 1 %}
            {% assign shown_ids = shown_ids | append: p.id | append: ',' %}
            {% if shown >= 8 %}{% break %}{% endif %}
          {% endunless %}
        {% endunless %}
      {% endfor %}
    {% endif %}
  {% endcapture %}

  {% if shown > 0 %}
    <section class="col-sec bp-related">
      <div class="sec-bg-grid"></div>
      <div class="sec-hdr rev sec-hdr--center">
        <h2 class="sec-title">TAMBIÉN TE PUEDE GUSTAR</h2>
      </div>
      <div class="related-wrap">
        <div class="related-track">
          {{ related_cards }}
          {{ related_cards }}
        </div>
      </div>
      {% if team_tag != blank %}
        {% assign team_name = team_tag | replace: '-', ' ' | capitalize %}
        <div class="related-actions">
          <a href="/search?q={{ team_tag | url_encode }}&type=product" class="btn-ver-mas">
            Ver todo de {{ team_name }} →
          </a>
        </div>
      {% endif %}
    </section>
  {% endif %}
</section>

<div id="modal-tallas" class="tallas-modal" data-default-tab="{{ talla_tab }}" role="dialog" aria-modal="true" aria-labelledby="tallas-modal-title" hidden>
  <div class="tallas-popup">
    <div class="tallas-popup__head">
      <h2 class="tallas-title" id="tallas-modal-title">Guía de tallas</h2>
      <button type="button" class="tallas-close" aria-label="Cerrar">✕</button>
    </div>

    <div class="tallas-popup__body">
      <div class="tallas-panels">
        {% if talla_tab == 'ninos' %}
        <div class="tallas-panel is-active" data-panel="ninos" role="tabpanel">
          <div class="tallas-table-wrap">
            <table class="tallas-table">
              <thead>
                <tr>
                  <th>Talla</th>
                  <th>Edad</th>
                  <th>Altura (cm)</th>
                  <th>Largo (cm)</th>
                  <th>Ancho (cm)</th>
                  <th>Cintura (cm)</th>
                </tr>
              </thead>
              <tbody>
                <tr><td>4</td><td>3-4</td><td>95-105</td><td>44</td><td>35</td><td>20-37</td></tr>
                <tr><td>6</td><td>4-5</td><td>105-115</td><td>47</td><td>37</td><td>21-39</td></tr>
                <tr><td>8</td><td>5-6</td><td>115-125</td><td>50</td><td>39</td><td>22-41</td></tr>
                <tr><td>10</td><td>6-7</td><td>125-135</td><td>53</td><td>41</td><td>23-42</td></tr>
                <tr><td>12</td><td>8-9</td><td>135-145</td><td>56</td><td>43</td><td>24-44</td></tr>
                <tr><td>14</td><td>10-11</td><td>145-155</td><td>59</td><td>45</td><td>25-47</td></tr>
                <tr><td>16</td><td>12-13</td><td>155-165</td><td>62</td><td>47</td><td>26-50</td></tr>
              </tbody>
            </table>
          </div>
          <p class="tallas-note">Largo = desde el hombro hacia abajo · Ancho = de axila a axila · Cintura = parte inferior de la prenda</p>
        </div>
        {% elsif talla_tab == 'fan' %}
        <div class="tallas-panel is-active" data-panel="fan" role="tabpanel">
          <div class="tallas-table-wrap">
            <table class="tallas-table">
              <thead>
                <tr>
                  <th>Talla</th>
                  <th>Largo (cm)</th>
                  <th>Ancho (cm)</th>
                  <th>Altura (cm)</th>
                  <th>Peso (kg)</th>
                </tr>
              </thead>
              <tbody>
                <tr><td>S</td><td>68-70</td><td>49-51</td><td>160-165</td><td>50-62</td></tr>
                <tr><td>M</td><td>70-72</td><td>51-53</td><td>165-170</td><td>62-70</td></tr>
                <tr><td>L</td><td>72-74</td><td>53-55</td><td>170-175</td><td>71-75</td></tr>
                <tr><td>XL</td><td>74-77</td><td>55-57</td><td>175-180</td><td>76-80</td></tr>
                <tr><td>2XL</td><td>77-79</td><td>57-59</td><td>180-185</td><td>81-89</td></tr>
                <tr><td>3XL</td><td>79-82</td><td>59-61</td><td>185-190</td><td>90-96</td></tr>
                <tr><td>4XL</td><td>83-85</td><td>61-63</td><td>190-195</td><td>97-106</td></tr>
              </tbody>
            </table>
          </div>
          <p class="tallas-note">Corte holgado, ideal para uso casual.</p>
        </div>
        {% elsif talla_tab == 'jugador' %}
        <div class="tallas-panel is-active" data-panel="jugador" role="tabpanel">
          <div class="tallas-table-wrap">
            <table class="tallas-table">
              <thead>
                <tr>
                  <th>Talla</th>
                  <th>Largo (cm)</th>
                  <th>Ancho (cm)</th>
                  <th>Peso (kg)</th>
                </tr>
              </thead>
              <tbody>
                <tr><td>S</td><td>69-71</td><td>45-47</td><td>48-62</td></tr>
                <tr><td>M</td><td>62-74</td><td>47-49</td><td>62-70</td></tr>
                <tr><td>L</td><td>74-75</td><td>49-51</td><td>68-75</td></tr>
                <tr><td>XL</td><td>76-78</td><td>51-53</td><td>72-80</td></tr>
                <tr><td>2XL</td><td>78-80</td><td>53-55</td><td>78-90</td></tr>
              </tbody>
            </table>
          </div>
          <p class="tallas-warn">Se recomienda 1 talla más para ajustada, 2 tallas más para suelta. Variación ±1-3 cm.</p>
        </div>
        {% elsif talla_tab == 'mujer' %}
        <div class="tallas-panel is-active" data-panel="mujer" role="tabpanel">
          <div class="tallas-table-wrap">
            <table class="tallas-table">
              <thead>
                <tr>
                  <th>Talla</th>
                  <th>Largo (cm)</th>
                  <th>Ancho (cm)</th>
                  <th>Altura (cm)</th>
                </tr>
              </thead>
              <tbody>
                <tr><td>S = P</td><td>61-63</td><td>40-41</td><td>150-160</td></tr>
                <tr><td>M = M</td><td>63-66</td><td>41-44</td><td>160-165</td></tr>
                <tr><td>L = G</td><td>66-69</td><td>44-47</td><td>165-170</td></tr>
                <tr><td>XL = GG</td><td>69-71</td><td>47-50</td><td>170-175</td></tr>
              </tbody>
            </table>
          </div>
        </div>
        {% elsif talla_tab == 'cortavientos' %}
        <div class="tallas-panel is-active" data-panel="cortavientos" role="tabpanel">
          <div class="tallas-table-wrap">
            <table class="tallas-table">
              <thead>
                <tr>
                  <th>Talla</th>
                  <th>Largo</th>
                  <th>Pecho</th>
                  <th>Hombros</th>
                  <th>Manga</th>
                  <th>Altura (cm)</th>
                  <th>Peso (kg)</th>
                </tr>
              </thead>
              <tbody>
                <tr><td>S</td><td>65</td><td>56</td><td>46</td><td>61</td><td>160-165</td><td>50-60</td></tr>
                <tr><td>M</td><td>67</td><td>58</td><td>47.5</td><td>62.5</td><td>165-170</td><td>60-70</td></tr>
                <tr><td>L</td><td>69</td><td>60</td><td>49</td><td>64</td><td>170-175</td><td>70-80</td></tr>
                <tr><td>XL</td><td>71</td><td>62</td><td>50.5</td><td>65.5</td><td>175-180</td><td>80-85</td></tr>
                <tr><td>XXL</td><td>73</td><td>64</td><td>52</td><td>67</td><td>180-185</td><td>85-95</td></tr>
              </tbody>
            </table>
          </div>
          <p class="tallas-warn">Aplica también para chaquetas. Variación ±2 cm.</p>
        </div>
        {% endif %}
      </div>

      {% render 'baul-tallas-guide-extra' %}
    </div>
  </div>
</div>

<script type="application/json" id="baul-product-json">
  {
    "variants": {{ product.variants | json }},
    "options": {{ product.options | json }},
    "moneyFormat": {{ shop.money_format | json }}
  }
</script>

{% schema %}
{
  "name": "Baúl Producto",
  "tag": "section",
  "class": "baul-product-section",
  "settings": [
    {
      "type": "header",
      "content": "Barra superior"
    },
    {
      "type": "text",
      "id": "countdown_text",
      "label": "Texto countdown",
      "default": "ENVÍO GRATIS POR TIEMPO LIMITADO — TERMINA EN:"
    },
    {
      "type": "text",
      "id": "promo_text",
      "label": "Banner promo",
      "default": "🎽 Lleva 3 camisetas y te llevas la 4ª a mitad de precio 🔥"
    },
    {
      "type": "header",
      "content": "Navbar"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo_secundario",
      "label": "Imagen junto al logo"
    },
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "WhatsApp URL"
    }
  ],
  "presets": [
    {
      "name": "Baúl Producto"
    }
  ]
}
{% endschema %}
