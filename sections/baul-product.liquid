{% comment %}
  Página de producto La Cábala
{% endcomment %}

{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign compare_at_price = current_variant.compare_at_price
  assign price = current_variant.price
  assign wa_url = 'https://wa.me/56948685507?text=Tengo%20una%20pregunta'

  if compare_at_price > price
    assign discount_amount = compare_at_price | minus: price
    assign discount_pct = discount_amount | times: 100 | divided_by: compare_at_price
  else
    assign discount_pct = 0
  endif

  assign vendor_label = product.vendor
  if vendor_label == blank
    assign vendor_label = product.type
  endif
%}

{% render 'baul-header', section: section %}

<section class="bp-page">
  <div class="sec-bg-grid"></div>
  <div class="bp-grid">
    <div class="bp-gallery">
      <div class="bp-main-img-wrap">
        {% if product.featured_image %}
          <img
            id="bp-main-img"
            class="bp-main-img"
            src="{{ product.featured_image | image_url: width: 1200 }}"
            alt="{{ product.featured_image.alt | default: product.title | escape }}"
            width="800"
            height="800"
            loading="eager"
          >
        {% else %}
          <div class="pc-bg">⚽</div>
        {% endif %}
      </div>
      {% if product.images.size > 1 %}
        <div class="bp-thumbs">
          {% for image in product.images %}
            <button
              type="button"
              class="bp-thumb{% if forloop.first %} is-active{% endif %}"
              data-src="{{ image | image_url: width: 1200 }}"
              aria-label="Ver imagen {{ forloop.index }}"
            >
              <img
                src="{{ image | image_url: width: 200 }}"
                alt="{{ image.alt | default: product.title | escape }}"
                width="80"
                height="80"
                loading="lazy"
              >
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="bp-info">
      <div class="bp-badges">
        <span class="bp-badge-urgency">🔥 ÚLTIMAS UNIDADES</span>
        <span class="bp-badge-ship">ENVÍO GRATIS</span>
      </div>

      <h1 class="bp-title">{{ product.title }}</h1>
      {% if vendor_label != blank or product.type != blank %}
        <p class="bp-subtitle">
          {% if product.vendor != blank %}{{ product.vendor }}{% endif %}
          {% if product.vendor != blank and product.type != blank %} · {% endif %}
          {% if product.type != blank %}{{ product.type }}{% endif %}
        </p>
      {% endif %}

      <div class="bp-price-row" id="bp-price-row">
        {% if compare_at_price > price %}
          <span class="p-old" id="bp-compare-price">{{ compare_at_price | money_without_trailing_zeros }}</span>
          <span class="p-new" id="bp-price">{{ price | money_without_trailing_zeros }}</span>
          <span class="bp-discount-badge">−{{ discount_pct }}%</span>
        {% else %}
          <span class="p-new" id="bp-price">{{ price | money_without_trailing_zeros }}</span>
        {% endif %}
      </div>

      <div class="bp-stock">
        <div class="urg-top">
          <div class="ult-dia">
            <div class="ult-dia-dot"></div>
            <span class="ult-dia-txt">ÚLTIMO DÍA — QUEDAN POCAS UNIDADES</span>
          </div>
        </div>
        <div class="urg-bar">
          <div class="urg-fill" style="width:28%;background:#ef4444;"></div>
          <div class="urg-clk" style="left:calc(28% - 5px)">⏱</div>
        </div>
      </div>

      {% form 'product', product, id: 'baul-product-form', class: 'bp-form' %}
        <input type="hidden" name="id" id="baul-variant-id" value="{{ current_variant.id }}">

        {% unless product.has_only_default_variant %}
          {% for option in product.options_with_values %}
            <div class="bp-option">
              <div class="bp-option-label">{{ option.name }}</div>
              <div class="bp-variants" data-option-index="{{ forloop.index0 }}">
                {% for value in option.values %}
                  {% assign opt_available = false %}
                  {% for variant in product.variants %}
                    {% if option.position == 1 and variant.option1 == value and variant.available %}
                      {% assign opt_available = true %}
                    {% elsif option.position == 2 and variant.option2 == value and variant.available %}
                      {% assign opt_available = true %}
                    {% elsif option.position == 3 and variant.option3 == value and variant.available %}
                      {% assign opt_available = true %}
                    {% endif %}
                  {% endfor %}
                  <button
                    type="button"
                    class="bp-variant-btn{% if current_variant.options[forloop.parentloop.index0] == value %} is-active{% endif %}{% unless opt_available %} is-unavailable{% endunless %}"
                    data-option-index="{{ forloop.parentloop.index0 }}"
                    data-value="{{ value | escape }}"
                  >
                    {{ value }}
                  </button>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        {% endunless %}

        {% render 'easify-pof__product-option' %}

        <button type="submit" name="add" class="bp-atc" id="bp-atc-btn"{% unless current_variant.available %} disabled{% endunless %}>
          AGREGAR AL CARRO
        </button>
      {% endform %}

      <div class="bp-trust">
        <span>🚚 Envío gratis</span>
        <span>🔒 Pago seguro</span>
      </div>
    </div>
  </div>

  {% if product.description != blank %}
    <div class="bp-desc-wrap">
      <div class="bp-desc rte">
        {{ product.description }}
      </div>
    </div>
  {% endif %}

  {% liquid
    assign related_collection = product.collections.first
    if related_collection
      assign related_products = related_collection.products
    else
      assign related_products = collections.all.products
    endif

    assign has_other_in_collection = false
    if related_collection
      for p in related_collection.products
        unless p.id == product.id
          assign has_other_in_collection = true
        endunless
      endfor
      unless has_other_in_collection
        assign related_products = collections.all.products
      endunless
    endif

    assign shown = 0
    assign shown_ids = ','
  %}
  {% if shop.products_count > 1 %}
    <section class="col-sec bp-related">
      <div class="sec-bg-grid"></div>
      <div class="sec-hdr rev sec-hdr--center">
        <h2 class="sec-title">TAMBIÉN TE PUEDE GUSTAR</h2>
      </div>
      <div class="prod-grid">
        {% for p in related_products %}
          {% unless p.id == product.id %}
            {% if shown < 4 %}
              {% assign pid_marker = ',' | append: p.id | append: ',' %}
              {% unless shown_ids contains pid_marker %}
                {% render 'baul-product-card', product: p %}
                {% assign shown = shown | plus: 1 %}
                {% assign shown_ids = shown_ids | append: p.id | append: ',' %}
              {% endunless %}
            {% endif %}
          {% endunless %}
        {% endfor %}
        {% if shown < 4 %}
          {% for p in collections.all.products %}
            {% unless p.id == product.id %}
              {% if shown < 4 %}
                {% assign pid_marker = ',' | append: p.id | append: ',' %}
                {% unless shown_ids contains pid_marker %}
                  {% render 'baul-product-card', product: p %}
                  {% assign shown = shown | plus: 1 %}
                  {% assign shown_ids = shown_ids | append: p.id | append: ',' %}
                {% endunless %}
              {% endif %}
            {% endunless %}
          {% endfor %}
        {% endif %}
      </div>
    </section>
  {% endif %}
</section>

<script type="application/json" id="baul-product-json">
  {
    "variants": {{ product.variants | json }},
    "options": {{ product.options | json }},
    "moneyFormat": {{ shop.money_format | json }}
  }
</script>

{% schema %}
{
  "name": "Baúl Producto",
  "tag": "section",
  "class": "baul-product-section",
  "settings": [
    {
      "type": "header",
      "content": "Barra superior"
    },
    {
      "type": "text",
      "id": "countdown_text",
      "label": "Texto countdown",
      "default": "ENVÍO GRATIS POR TIEMPO LIMITADO — TERMINA EN:"
    },
    {
      "type": "text",
      "id": "promo_text",
      "label": "Banner promo",
      "default": "🎽 Lleva 3 camisetas y te llevas la 4ª a mitad de precio 🔥"
    },
    {
      "type": "header",
      "content": "Navbar"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo_secundario",
      "label": "Imagen junto al logo"
    },
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "WhatsApp URL"
    }
  ],
  "presets": [
    {
      "name": "Baúl Producto"
    }
  ]
}
{% endschema %}
