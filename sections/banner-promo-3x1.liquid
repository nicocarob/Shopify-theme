{% comment %} banner-promo-3x1.liquid {% endcomment %}

<div class="promo-3x1-section" style="
  background: {{ section.settings.bg_color }};
  margin: {{ section.settings.margin_top }}px {{ section.settings.margin_sides }}px {{ section.settings.margin_bottom }}px;
  border-radius: 10px;
  padding: 10px 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  text-align: center;
">
  <p style="
    margin: 0;
    font-size: 0.82rem;
    font-weight: 800;
    color: {{ section.settings.text_color }};
    letter-spacing: 0.3px;
    line-height: 1.3;
  ">
    {{ section.settings.emoji }} {{ section.settings.texto }} <strong>{{ section.settings.texto_bold }}</strong> {{ section.settings.emoji_end }}
  </p>
</div>

{% schema %}
{
  "name": "Banner Promo 3x1",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "texto",
      "label": "Texto principal",
      "default": "Lleva 3 camisetas y la 4ª es"
    },
    {
      "type": "text",
      "id": "texto_bold",
      "label": "Texto en negrita",
      "default": "GRATIS"
    },
    {
      "type": "text",
      "id": "emoji",
      "label": "Emoji izquierda",
      "default": "🎽"
    },
    {
      "type": "text",
      "id": "emoji_end",
      "label": "Emoji derecha",
      "default": "🔥"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#00e676"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margen arriba",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 10
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margen abajo",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 10
    },
    {
      "type": "range",
      "id": "margin_sides",
      "label": "Margen lados",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Banner Promo 3x1"
    }
  ]
}
{% endschema %}
