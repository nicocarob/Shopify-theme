{% comment %}
  Lista de colecciones La Cábala
{% endcomment %}

{% render 'baul-header', section: section %}

<section class="blc-page">
  <div class="sec-bg-grid"></div>
  <div class="blc-hdr rev">
    <h1 class="sec-title">{{ section.settings.title | default: 'TODAS LAS COLECCIONES' }}</h1>
  </div>
  <div class="blc-grid">
    {% for col in collections %}
      {% if col.all_products_count > 0 %}
        <a href="{{ col.url }}" class="blc-card rev-s">
          <div class="blc-img-wrap">
            {% if col.featured_image %}
              <img
                src="{{ col.featured_image | image_url: width: 600 }}"
                alt="{{ col.featured_image.alt | default: col.title | escape }}"
                width="400"
                height="400"
                loading="lazy"
              >
            {% elsif col.products.first.featured_image %}
              <img
                src="{{ col.products.first.featured_image | image_url: width: 600 }}"
                alt="{{ col.title | escape }}"
                width="400"
                height="400"
                loading="lazy"
              >
            {% else %}
              <div class="pc-bg">⚽</div>
            {% endif %}
          </div>
          <h2 class="blc-name">{{ col.title }}</h2>
          <span class="btn-v blc-btn">VER COLECCIÓN</span>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Baúl Lista Colecciones",
  "tag": "section",
  "class": "baul-list-collections-section",
  "settings": [
    {
      "type": "header",
      "content": "Barra superior"
    },
    {
      "type": "text",
      "id": "countdown_text",
      "label": "Texto countdown",
      "default": "ENVÍO GRATIS POR TIEMPO LIMITADO — TERMINA EN:"
    },
    {
      "type": "text",
      "id": "promo_text",
      "label": "Banner promo",
      "default": "🎽 Lleva 3 camisetas y te llevas la 4ª a mitad de precio 🔥"
    },
    {
      "type": "header",
      "content": "Navbar"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo_secundario",
      "label": "Imagen junto al logo"
    },
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "TODAS LAS COLECCIONES"
    }
  ],
  "presets": [
    {
      "name": "Baúl Lista Colecciones"
    }
  ]
}
{% endschema %}
