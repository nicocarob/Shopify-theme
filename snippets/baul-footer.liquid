{% comment %}
  Footer compartido La Cábala — funciona sin section (layout global)
{% endcomment %}

{% liquid
  assign footer_description = 'Más de 10 años equipando hinchas en todo Chile. La mejor calidad, envío gratis y atención personalizada.'
  assign wa_url = 'https://wa.me/56948685507?text=Tengo%20una%20pregunta'
  if whatsapp_url != blank
    assign wa_url = whatsapp_url
  endif
%}

<footer>
  <div class="ft-grid">
    <div>
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
        <img src="https://www.lacabala.cl/cdn/shop/files/ANUNCIOS_5.png" width="44" height="44" style="object-fit:contain;" alt="{{ shop.name | escape }}">
        <span style="font-family:'Bebas Neue',sans-serif;font-size:26px;color:#fff;letter-spacing:.05em;">LA CÁBALA</span>
      </div>
      <p class="ft-desc">{{ footer_description }}</p>
      <div class="ft-soc">
        <a class="ft-s ft-s--wa" href="{{ wa_url }}" target="_blank" rel="noopener" aria-label="WhatsApp">
          {% render 'baul-whatsapp-icon' %}
        </a>
      </div>
    </div>
    <div>
      <div class="ft-col-t">Ligas</div>
      <ul class="ft-links">
        <li><a href="{{ collections['liga-chilena'].url | default: '/collections/liga-chilena' }}">Liga Chilena</a></li>
        <li><a href="{{ collections['liga-espanola'].url | default: '/collections/liga-espanola' }}">Liga Española</a></li>
        <li><a href="{{ collections['premier-league'].url | default: '/collections/premier-league' }}">Premier League</a></li>
        <li><a href="{{ collections['serie-a'].url | default: '/collections/serie-a' }}">Serie A</a></li>
        <li><a href="/collections/copa-del-mundo">Selecciones</a></li>
      </ul>
    </div>
    <div>
      <div class="ft-col-t">Colecciones</div>
      <ul class="ft-links">
        <li><a href="/collections/copa-del-mundo">Copa del Mundo 2026</a></li>
        <li><a href="{{ collections['retro'].url | default: '/collections/retro' }}">Retro</a></li>
        <li><a href="{{ collections['ninos'].url | default: '/collections/ninos' }}">Niños</a></li>
        <li><a href="{{ collections['mujer'].url | default: '/collections/mujer' }}">Femenino</a></li>
        <li><a href="{{ collections['liquidacion'].url | default: '/collections/liquidacion' }}">Liquidación</a></li>
      </ul>
    </div>
    <div>
      <div class="ft-col-t">Ayuda</div>
      <ul class="ft-links">
        <li><a href="{{ pages['politica-de-envios'].url | default: '/pages/politica-de-envios' }}">Política de envíos</a></li>
        <li><a href="{{ pages['terminos-del-servicio'].url | default: '/pages/terminos-del-servicio' }}">Términos del servicio</a></li>
        <li><a href="{{ pages['politica-de-reembolso'].url | default: '/pages/politica-de-reembolso' }}">Política de reembolso</a></li>
        <li><a href="https://www.instagram.com/lacabala.chile" target="_blank" rel="noopener">Instagram</a></li>
        <li><a href="{{ wa_url }}" target="_blank" rel="noopener">WhatsApp</a></li>
      </ul>
    </div>
  </div>
  <div class="ft-bot">
    <div class="ft-copy-row">
      <img
        class="ft-copy-logo"
        src="https://www.lacabala.cl/cdn/shop/files/ANUNCIOS_5.png"
        alt="{{ shop.name | escape }}"
        width="24"
        height="24"
        style="object-fit:contain;"
        loading="lazy"
      >
      <span class="ft-copy">© 2026 La Cábala — Todos los derechos reservados</span>
    </div>
  </div>
</footer>

{% render 'baul-whatsapp-float', wa_url: wa_url %}
