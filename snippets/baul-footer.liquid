{% comment %}
  Footer compartido La Cábala
  Parámetro opcional: section (settings del bloque padre)
{% endcomment %}

{% liquid
  assign logo_img = blank
  assign footer_description = 'Más de 10 años equipando hinchas en todo Chile. La mejor calidad, envío gratis y atención personalizada.'
  assign instagram_url = blank
  assign wa_url = 'https://wa.me/56951543485'

  if section != blank
    assign logo_img = section.settings.logo
    if section.settings.footer_description != blank
      assign footer_description = section.settings.footer_description
    endif
    assign instagram_url = section.settings.instagram_url
    if section.settings.whatsapp_url != blank
      assign wa_url = section.settings.whatsapp_url
    endif
  endif

  if logo_img == blank
    assign logo_src = 'baul-logo.png' | asset_url
    assign copyright_logo_src = logo_src
  else
    assign logo_src = logo_img | image_url: width: 104
    assign copyright_logo_src = logo_img | image_url: width: 48
  endif
%}

<footer>
  <div class="ft-grid">
    <div>
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
        <img src="{{ logo_src }}" style="width:44px;height:44px;object-fit:contain;" alt="{{ shop.name | escape }}" width="44" height="44">
        <span style="font-family:'Bebas Neue',sans-serif;font-size:26px;color:#fff;letter-spacing:.05em;">LA CÁBALA</span>
      </div>
      <p class="ft-desc">{{ footer_description }}</p>
      <div class="ft-soc">
        {% if instagram_url != blank %}
          <a class="ft-s" href="{{ instagram_url }}" target="_blank" rel="noopener">📸</a>
        {% endif %}
        <a class="ft-s" href="{{ wa_url }}" target="_blank" rel="noopener">💬</a>
      </div>
    </div>
    <div>
      <div class="ft-col-t">Ligas</div>
      <ul class="ft-links">
        <li><a href="{{ collections['liga-chilena'].url | default: '/collections/liga-chilena' }}">Liga Chilena</a></li>
        <li><a href="{{ collections['liga-espanola'].url | default: '/collections/liga-espanola' }}">Liga Española</a></li>
        <li><a href="{{ collections['premier-league'].url | default: '/collections/premier-league' }}">Premier League</a></li>
        <li><a href="{{ collections['serie-a'].url | default: '/collections/serie-a' }}">Serie A</a></li>
        <li><a href="/collections/copa-del-mundo">Selecciones</a></li>
      </ul>
    </div>
    <div>
      <div class="ft-col-t">Colecciones</div>
      <ul class="ft-links">
        <li><a href="/collections/copa-del-mundo">Copa del Mundo 2026</a></li>
        <li><a href="{{ collections['retro'].url | default: '/collections/retro' }}">Retro</a></li>
        <li><a href="{{ collections['ninos'].url | default: '/collections/ninos' }}">Niños</a></li>
        <li><a href="{{ collections['mujer'].url | default: '/collections/mujer' }}">Femenino</a></li>
        <li><a href="{{ collections['liquidacion'].url | default: '/collections/liquidacion' }}">Liquidación</a></li>
      </ul>
    </div>
    <div>
      <div class="ft-col-t">Ayuda</div>
      <ul class="ft-links">
        <li><a href="{{ pages['politica-de-envios'].url | default: '/pages/politica-de-envios' }}">Política de envíos</a></li>
        <li><a href="{{ pages['devoluciones'].url | default: '/pages/devoluciones' }}">Devoluciones</a></li>
        <li><a href="{{ pages['guia-de-tallas'].url | default: '/pages/guia-de-tallas' }}">Guía de tallas</a></li>
        <li><a href="{{ pages['personalizacion'].url | default: '/pages/personalizacion' }}">Personalización</a></li>
        <li><a href="{{ wa_url }}" target="_blank" rel="noopener">WhatsApp</a></li>
      </ul>
    </div>
  </div>
  <div class="ft-bot">
    <div class="ft-copy-row">
      <img
        class="ft-copy-logo"
        src="{{ copyright_logo_src }}"
        alt="{{ shop.name | escape }}"
        width="24"
        height="24"
        loading="lazy"
      >
      <span class="ft-copy">© 2026 La Cábala — Todos los derechos reservados</span>
    </div>
    <span class="ft-copy">Hecho con ⚽ en Chile</span>
  </div>
</footer>

<a class="wa" href="{{ wa_url }}" target="_blank" rel="noopener" aria-label="WhatsApp">💬</a>
