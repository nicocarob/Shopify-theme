{% comment %}
  Header compartido: countdown, ticker, promo y navbar
  Parámetro: section (settings del bloque padre)
{% endcomment %}

{% liquid
  assign logo_secundario = blank
  assign promo_text = '🎽 Lleva 3 camisetas y te llevas la 4ª a mitad de precio 🔥'

  if section != blank
    assign logo_secundario = section.settings.logo_secundario
    assign promo_text = section.settings.promo_text | default: promo_text
  endif
%}

{% capture logo_src %}{% render 'baul-logo-url', section: section, width: 104 %}{% endcapture %}

<div id="cbar">
  <div class="cbar-inner">
    <div class="cbar-main">
      <span class="cbar-text">⏱️ ENVÍO GRATIS A TODO CHILE POR TIEMPO LIMITADO 🇨🇱</span>
      <span class="cbar-sub">EL ENVÍO GRATIS TERMINA EN:</span>
    </div>
    <div class="cbar-line cbar-line--timer">
      <span class="ctimer" id="mainTimer">00:00:00</span>
    </div>
  </div>
</div>

<div class="ticker">
  <div class="tick-tr">
    {% for i in (1..2) %}
      <span class="tick-it"><b>⚽</b>ENVÍO GRATIS A TODO CHILE</span>
      <span class="tick-it"><b>🎽</b>PERSONALIZA TU CAMISETA</span>
      <span class="tick-it"><b>⭐</b>MÁS DE 10 AÑOS DE EXPERIENCIA</span>
      <span class="tick-it"><b>🔥</b>LLEVA 3, LA 4ª A MITAD DE PRECIO</span>
      <span class="tick-it"><b>🏆</b>COPA DEL MUNDO 2026</span>
    {% endfor %}
  </div>
</div>

<div class="promo-banner">
  <p>{{ promo_text }}</p>
</div>

<nav>
  <a class="n-logo" href="{{ routes.root_url }}">
    <img src="{{ logo_src }}" alt="{{ shop.name | escape }}" width="52" height="52">
    {% if logo_secundario != blank %}
      <img
        class="n-logo-sec"
        src="{{ logo_secundario | image_url: height: 80 }}"
        alt=""
        width="40"
        height="40"
        loading="lazy"
      >
    {% endif %}
  </a>
  <form class="n-search" id="n-search-form" action="{{ routes.search_url }}" method="get" role="search">
    <input type="hidden" name="type" value="product">
    <input
      class="n-search-in"
      type="search"
      name="q"
      placeholder="Buscar equipo o camiseta..."
      autocomplete="off"
      aria-label="Buscar equipo o camiseta"
    >
  </form>
  <button type="button" class="n-hamburger" id="n-hamburger" aria-expanded="false" aria-label="Abrir menú de navegación">☰</button>
  <ul class="n-links" id="n-links">
    <li><a href="{{ collections['liga-chilena'].url | default: '/collections/liga-chilena' }}">🇨🇱 Liga Chilena</a></li>
    <li><a href="{{ collections['liga-espanola'].url | default: '/collections/liga-espanola' }}">🇪🇸 Española</a></li>
    <li><a href="{{ collections['premier-league'].url | default: '/collections/premier-league' }}">🏴󠁧󠁢󠁥󠁮󠁧󠁿 Premier</a></li>
    <li><a href="https://www.lacabala.cl/collections/copa-del-mundo">🌍 Selecciones</a></li>
    <li><a href="{{ collections['retro'].url | default: '/collections/retro' }}">🕰️ Retro</a></li>
    <li><a href="{{ collections['ninos'].url | default: '/collections/ninos' }}">👦 Niños</a></li>
    <li><a href="{{ collections['mujer'].url | default: '/collections/mujer' }}">👩 Mujer</a></li>
  </ul>
  <a href="{{ routes.cart_url }}" class="btn-cart">🛒 Carrito ({{ cart.item_count }})</a>
</nav>
